using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace TipoParcial.BibliotecaDigital.Modelos
{
    public abstract class MaterialBiblioteca
    {
        public string Id { get; set; }
        public string Titulo { get; set; }
        public string Autor { get; set; }
        public int AnioPublicacion { get; set; }
        public string Categoria { get; set; }

        protected MaterialBiblioteca(string id, string titulo, string autor, int anio, string categoria)
        {
            Id = id;
            Titulo = titulo;
            Autor = autor;
            AnioPublicacion = anio;
            Categoria = categoria;
        }

        public virtual void MostrarInformacion()
        {
            Console.WriteLine("Información del Material de Biblioteca:");
            Console.WriteLine($"[ID: {Id}] - {Titulo}");
            Console.WriteLine($"Autor: {Autor} | Año: {AnioPublicacion}");
            Console.WriteLine($"Categoría: {Categoria}");
        }
    }
}